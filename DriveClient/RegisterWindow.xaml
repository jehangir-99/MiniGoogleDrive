<Window x:Class="DriveClient.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Account"
        Height="520"
        Width="920"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#ECEFF4">

    <Grid>

        <!-- MAIN CARD -->
        <Border Width="800"
                Height="440"
                Background="White"
                CornerRadius="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT SIDE -->
                <Border Background="#10B981"
                        CornerRadius="20,0,0,20">

                    <StackPanel VerticalAlignment="Center"
                                Margin="35">

                        <TextBlock Text="☁"
                                   FontSize="60"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="Join Google Drive"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   TextAlignment="Center"
                                   Margin="0,15,0,0"/>

                        <TextBlock Text="Create your free account"
                                   Margin="0,15,0,0"
                                   FontSize="16"
                                   Foreground="#E5E7EB"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"/>

                        <TextBlock Text="Secure • Fast • Simple"
                                   Margin="0,30,0,0"
                                   FontSize="14"
                                   Foreground="#D1FAE5"
                                   TextAlignment="Center"/>

                    </StackPanel>

                </Border>

                <!-- RIGHT SIDE -->
                <Grid Grid.Column="1"
                      Margin="55">

                    <StackPanel VerticalAlignment="Center">

                        <!-- TITLE -->
                        <TextBlock Text="Create Account"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="#111827"/>

                        <TextBlock Text="Fill details to register"
                                   Margin="0,6,0,30"
                                   Foreground="#6B7280"
                                   FontSize="14"/>

                        <!-- USERNAME -->
                        <TextBlock Text="Username"
                                   FontWeight="SemiBold"
                                   Foreground="#374151"/>

                        <TextBox x:Name="UsernameBox"/>

                        <!-- PASSWORD -->
                        <TextBlock Text="Password"
                                   Margin="0,12,0,0"
                                   FontWeight="SemiBold"
                                   Foreground="#374151"/>

                        <PasswordBox x:Name="PasswordBox"
                                     Height="42"
                                     Padding="10"
                                     FontSize="14"
                                     Background="#F9FAFB"
                                     BorderBrush="#D1D5DB"
                                     BorderThickness="1"/>

                        <!-- REGISTER BUTTON -->
                        <Button Content="Create Account"
                                Background="#10B981"
                                Margin="0,25,0,0"
                                Click="Register_Click"/>

                        <!-- BACK TO LOGIN -->
                        <TextBlock Text="Already have an account? Login"
                                   Foreground="#4F46E5"
                                   Cursor="Hand"
                                   HorizontalAlignment="Center"
                                   Margin="0,20,0,0"
                                   MouseDown="GoToLogin_Click"/>

                        <!-- STATUS -->
                        <TextBlock x:Name="StatusText"
                                   Margin="0,25,0,0"
                                   Foreground="#6B7280"
                                   HorizontalAlignment="Center"
                                   FontSize="13"/>

                    </StackPanel>

                </Grid>

            </Grid>

        </Border>

    </Grid>
</Window>